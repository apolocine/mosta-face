{
  "name": "@mostajs/face",
  "version": "1.3.5",
  "description": "Reusable face recognition module — detection, descriptor extraction, 1:N matching",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hooks/useCamera": {
      "types": "./dist/hooks/useCamera.d.ts",
      "import": "./dist/hooks/useCamera.js",
      "require": "./dist/hooks/useCamera.js",
      "default": "./dist/hooks/useCamera.js"
    },
    "./hooks/useFaceDetection": {
      "types": "./dist/hooks/useFaceDetection.d.ts",
      "import": "./dist/hooks/useFaceDetection.js",
      "require": "./dist/hooks/useFaceDetection.js",
      "default": "./dist/hooks/useFaceDetection.js"
    },
    "./components/FaceDetector": {
      "types": "./dist/components/FaceDetector.d.ts",
      "import": "./dist/components/FaceDetector.js",
      "default": "./dist/components/FaceDetector.js"
    },
    "./lib/face-api": {
      "types": "./dist/lib/face-api.d.ts",
      "import": "./dist/lib/face-api.js",
      "default": "./dist/lib/face-api.js"
    },
    "./lib/face-matcher": {
      "types": "./dist/lib/face-matcher.d.ts",
      "import": "./dist/lib/face-matcher.js",
      "default": "./dist/lib/face-matcher.js"
    },
    "./lib/face-utils": {
      "types": "./dist/lib/face-utils.d.ts",
      "import": "./dist/lib/face-utils.js",
      "default": "./dist/lib/face-utils.js"
    },
    "./api/recognize.route": {
      "types": "./dist/api/recognize.route.d.ts",
      "import": "./dist/api/recognize.route.js",
      "default": "./dist/api/recognize.route.js"
    },
    "./api/detect.route": {
      "types": "./dist/api/detect.route.d.ts",
      "import": "./dist/api/detect.route.js",
      "default": "./dist/api/detect.route.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./lib/menu": {
      "types": "./dist/lib/menu.d.ts",
      "import": "./dist/lib/menu.js",
      "default": "./dist/lib/menu.js"
    }
  },
  "files": [
    "dist",
    "face.wire.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "face-recognition",
    "face-detection",
    "face-api",
    "biometrics",
    "react",
    "mosta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-face"
  },
  "homepage": "https://mostajs.dev/packages/face",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.0"
  },
  "peerDependencies": {
    "@mostajs/menu": ">=1.0.2",
    "react": ">=18"
  },
  "devDependencies": {
    "@mostajs/menu": "^1.0.2",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependenciesMeta": {
    "@mostajs/menu": {
      "optional": true
    }
  }
}
